{
  "name": "fl-dance-electron",
  "version": "0.0.1",
  "description": "FL dance but made in electron.",
  "main": "main.js",
  "type": "commonjs",

  "scripts": {
    "dev": "electron .",
    "build": "electron-builder"
  },

  "build": {
    "appId": "com.nicholasc2.fl-dance",
    "productName": "FL Dance Electron",

    "win": {
      "target": "nsis"
    },

    "linux": {
      "target": ["AppImage"]
    },

    "mac": {
      "target": ["dmg"]
    }
  },

  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  }
}