{
  "name": "desktop-pets-electron",
  "version": "0.3.1",
  "description": "Simple desktop pets.",
  "main": "dist/main.js",
  "type": "commonjs",
  "scripts": {
    "build:ts": "tsc",
    "dev": "npm run build:ts && electron .",
    "build": "npm run build:ts && electron-builder",
    "update-deps": "npm update"
  },
  "build": {
    "appId": "com.nicholasc2.desktop-pets",
    "productName": "Desktop Pets",
    "files": [
      "dist/**/*.js",
      "html/**"
    ],
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "icon": "icon.png"
  },
  "devDependencies": {
    "@types/unzipper": "^0.10.11",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@types/electron": "^1.4.38",
    "@types/electron-store": "^1.3.1",
    "electron-store": "^11.0.2",
    "unzipper": "^0.12.3"
  }
}
