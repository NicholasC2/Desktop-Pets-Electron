{
  "name": "desktop-pets-electron",
  "version": "0.1.0",
  "description": "Simple desktop pets.",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.nicholasc2.desktop-pets",
    "productName": "Desktop Pets",
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "icon": "icon.png"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "unzipper": "^0.12.3"
  }
}
