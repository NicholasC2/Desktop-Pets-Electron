{
  "name": "fl-dance",
  "displayName": "fl-dance",
  "description": "FL Dance in vs-code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "enabledApiProposals": [],
  "contributes": {
    "commands": [
      {
        "command": "fl-dance.open",
        "title": "Open FL Dance"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "update-proposed-api": "vscode-dts dev"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vscode-dts": "^0.3.3"
  },
  "dependencies": {
    "electron": "^42.2.0"
  }
}
